# Database Configuration
DB_HOST="localhost"
DB_PORT="5432"
DB_USER="postgres"
DB_PASSWORD="postgrespassword"
DB_NAME="uplive_db"
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/uplive_db?schema=public"

# Docker Database Configuration
DOCKER_DB_HOST="postgres"
DOCKER_DB_PORT="5432"
DOCKER_DB_USER="postgres"
DOCKER_DB_PASSWORD="postgrespassword"
DOCKER_DB_NAME="uplive_db"
DOCKER_DATABASE_URL="postgresql://postgres:postgrespassword@postgres:5432/uplive_db?schema=public"
DOCKER_STORAGE_ROOT="/app/data"
DOCKER_YT_DLP_BIN="/usr/local/bin/yt-dlp"
DOCKER_FFMPEG_BIN="/usr/bin/ffmpeg"
DOCKER_FFPROBE_BIN="/usr/bin/ffprobe"

# Application Configuration
APP_URL="http://localhost:3001"
PORT=3000
NODE_ENV="development"
STORAGE_ROOT="./data"

# Media Binaries
YT_DLP_BIN="yt-dlp"
FFMPEG_BIN="ffmpeg"
FFPROBE_BIN="ffprobe"
